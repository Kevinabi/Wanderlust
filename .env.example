# Wanderlust — Environment Variables
# Copy this file to ".env" and fill in your own values. Never commit ".env".
#
# RapidAPI key for the IRCTC1 API (PNR + Live Train Status + Trains Between Stations)
#   1. Sign up free at https://rapidapi.com
#   2. Subscribe to https://rapidapi.com/IRCTCAPI/api/irctc1  (free tier: 100 req/day)
#   3. Dashboard → Apps → default-application → Security tab → copy the key
RAPIDAPI_KEY=your_rapidapi_key_here

# Port for the local Express dev server (server.js). Not used on Vercel.
PORT=3001
